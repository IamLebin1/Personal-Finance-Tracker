{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["jest", "react", "react-native"],
    "lib": ["esnext"]
  },
  "include": ["**/*.ts", "**/*.tsx", "index.js"],
  "exclude": ["**/node_modules", "**/Pods"]
}
